# 环境变量配置
# 复制此文件为 .env 并填入实际值

# LangSmith Tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=edagent-vivado

# Anthropic API Key (required for agent mode)
ANTHROPIC_API_KEY=

# OpenAI-compatible BYOK / gateway mode (optional)
# EDAGENT_MODEL_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.example.com/v1
# EDAGENT_REASONING_EFFORT=medium

# 模型选择 (Anthropic 默认 claude-sonnet-4-20250514；OpenAI-compatible 示例 gpt-5.5)
EDAGENT_MODEL=claude-sonnet-4-20250514

# Vivado 路径 (可选，默认自动查找)
# VIVADO_PATH=/opt/Xilinx/Vivado/2022.1/bin/vivado
